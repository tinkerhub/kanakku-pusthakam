POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_USER=makerspace
POSTGRES_DB=makerspace_manager

SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=inventory.example.org
CORS_ALLOWED_ORIGINS=https://inventory.example.org
# Fernet key for API client, Telegram bot token, and makerspace SMTP password encryption.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_CLIENT_ENC_KEY=

# Security hardening. Leave ENABLE_HTTPS=false for the default HTTP-behind-nginx
# Docker setup. Set it to true ONLY when a proxy terminates real TLS and forwards
# X-Forwarded-Proto: https — it turns on SSL redirect, Secure cookies, and HSTS.
ENABLE_HTTPS=false
# Brute-force lockout (django-axes) on the Django admin login.
AXES_FAILURE_LIMIT=5

MAKERSPACE_BACKEND_IMAGE=ghcr.io/shaan-shoukath/makerspace-manager-backend
MAKERSPACE_FRONTEND_IMAGE=ghcr.io/shaan-shoukath/makerspace-manager-frontend
MAKERSPACE_IMAGE_TAG=latest
HTTP_PORT=80

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Makerspace <noreply@example.com>

# Public catalog images live in a separate anonymous-read bucket. Use this only
# for item photos and makerspace logo/cover images, never private evidence.
PUBLIC_IMAGE_BUCKET=public-images
PUBLIC_IMAGE_BASE_URL=http://localhost:9000/public-images
PUBLIC_IMAGE_MAX_BYTES=5242880
PUBLIC_IMAGE_URL_TTL_SECONDS=300

# Telegram. Per-makerspace bot tokens + group chat ids are stored (encrypted) in the
# DB; these are the optional global fallback bot and the webhook auth secret. Set
# TELEGRAM_WEBHOOK_SECRET so accept/reject webhook callbacks are trusted — the webhook
# fails closed (rejects every callback) when it is unset.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Managed-Postgres / Supabase mode (all default to the self-hosted localhost behavior) ---
# See docs/supabase-deployment.md. Leave these at their defaults for the bundled
# Docker (local Postgres + MinIO) stack; set them only when hosting on Supabase et al.
#
# MANAGED_POSTGRES=true makes makerspace purge suspend immutability triggers via a
# custom GUC (no superuser) instead of session_replication_role (which Supabase forbids).
MANAGED_POSTGRES=False
# Transaction-pooler runtime (Supabase port 6543) cannot keep prepared statements or
# server-side cursors: set CONN_MAX_AGE=0 and DISABLE_SERVER_SIDE_CURSORS=True there.
# Run `manage.py migrate` against the DIRECT/session-pooler URL, not the transaction pooler.
CONN_MAX_AGE=0
DISABLE_SERVER_SIDE_CURSORS=False
# Object storage presign style. "post" = MinIO/S3 browser POST policy (default, with an
# upload-time content-length-range). "put" = Supabase Storage S3 presigned PUT (no
# upload-time size policy; the backend re-validates size server-side at attach time).
STORAGE_PRESIGN_METHOD=post
# Shared secret for the cron return-reminder endpoint
# (POST /api/v1/internal/cron/return-reminders, header X-Cron-Secret). The endpoint
# 404s while this is unset. Use it when you can't run `manage.py send_return_reminders`
# on a schedule (e.g. trigger from GitHub Actions / cron-job.org / pg_cron+pg_net).
CRON_SECRET=
