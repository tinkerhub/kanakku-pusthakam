# CHECKLIST
# - Use Supabase Pro for production runtime Postgres: no free-tier pause, 8 GB DB, daily backups.
# - Generate and store SECRET_KEY plus API_CLIENT_ENC_KEY in an offline password vault.
# - Use the Supabase transaction pooler URL for runtime; run migrations with the direct/session URL.
# - Use the Cloudflare R2 S3 API endpoint for BOTH endpoint vars, not an r2.dev/custom domain.
# - Set EMAIL_BACKEND when enabling Brevo SMTP; otherwise mail only logs and email_enabled() is off.
# - Set CRON_SECRET before configuring the daily return-reminders cron.

# --- Core secrets and hosts ---
# LOCAL (Docker self-hosted): replace-with-a-long-random-secret   |   CLOUD (lean-paid): long unique secret from a password manager
SECRET_KEY=replace-with-a-long-random-secret

# LOCAL (Docker self-hosted): generated Fernet key, optional for local demos   |   CLOUD (lean-paid): REQUIRED Fernet key; back up offline or encrypted SMTP/Telegram/API secrets are unrecoverable
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_CLIENT_ENC_KEY=

# LOCAL (Docker self-hosted): False   |   CLOUD (lean-paid): False
DEBUG=False

# LOCAL (Docker self-hosted): localhost,127.0.0.1   |   CLOUD (lean-paid): <render-host>.onrender.com or api.example.org
ALLOWED_HOSTS=<render-host>.onrender.com

# LOCAL (Docker self-hosted): http://localhost:5000   |   CLOUD (lean-paid): https://<frontend-origin>
CORS_ALLOWED_ORIGINS=https://<frontend-origin>

# LOCAL (Docker self-hosted): blank   |   CLOUD (lean-paid): https://<render-host>.onrender.com
CSRF_TRUSTED_ORIGINS=https://<render-host>.onrender.com

# --- HTTPS behind Render ---
# Render terminates TLS upstream and forwards X-Forwarded-Proto.
# LOCAL (Docker self-hosted): false   |   CLOUD (lean-paid): true
ENABLE_HTTPS=true

# LOCAL (Docker self-hosted): false   |   CLOUD (lean-paid): true
TRUST_X_FORWARDED_PROTO=true

# LOCAL (Docker self-hosted): 0   |   CLOUD (lean-paid): 0 at first, then a short value once HTTPS is verified
# When SECURE_HSTS_SECONDS > 0, this app also enables includeSubDomains and preload.
# Do not preload until the whole apex domain and every subdomain are HTTPS-ready.
SECURE_HSTS_SECONDS=0

# --- Database: Supabase Pro Postgres ---
# LOCAL (Docker self-hosted): postgres://makerspace:<password>@localhost:5432/makerspace_manager   |   CLOUD (lean-paid): Supabase transaction pooler URL, port 6543
# Runtime uses the transaction pooler. Run migrations one-off against the direct/session URL on port 5432 instead.
DATABASE_URL=postgres://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# LOCAL (Docker self-hosted): False   |   CLOUD (lean-paid): True
MANAGED_POSTGRES=True

# LOCAL (Docker self-hosted): 0   |   CLOUD (lean-paid): 0 for Supabase transaction pooler
CONN_MAX_AGE=0

# LOCAL (Docker self-hosted): False   |   CLOUD (lean-paid): True for Supabase transaction pooler
DISABLE_SERVER_SIDE_CURSORS=True

# --- Storage: Cloudflare R2, S3-compatible ---
# LOCAL (Docker self-hosted): evidence   |   CLOUD (lean-paid): your R2 bucket name
AWS_STORAGE_BUCKET_NAME=makerspace-evidence

# Public catalog image bucket. This bucket must be public-read by policy; use it
# only for inventory item photos and makerspace logo/cover images.
PUBLIC_IMAGE_BUCKET=makerspace-public-images

# LOCAL (Docker self-hosted): http://localhost:9000   |   CLOUD (lean-paid): https://<account-id>.r2.cloudflarestorage.com
# Use the R2 S3 API domain for signed URLs. Do NOT use an r2.dev/custom public domain here.
AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# LOCAL (Docker self-hosted): http://localhost:9000   |   CLOUD (lean-paid): https://<account-id>.r2.cloudflarestorage.com
# Must match the S3 API domain above because presigned PUT/GET URLs are signed for this host.
AWS_S3_PUBLIC_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# Browser-facing public URL for PUBLIC_IMAGE_BUCKET (R2 custom domain/r2.dev,
# Supabase public bucket URL, or MinIO public bucket URL).
PUBLIC_IMAGE_BASE_URL=https://<public-image-domain>

# Max public image upload size and presigned upload URL TTL.
PUBLIC_IMAGE_MAX_BYTES=5242880
PUBLIC_IMAGE_URL_TTL_SECONDS=300

# LOCAL (Docker self-hosted): minioadmin or local key   |   CLOUD (lean-paid): R2 S3 API access key id
AWS_ACCESS_KEY_ID=<r2-access-key-id>

# LOCAL (Docker self-hosted): minioadmin or local secret   |   CLOUD (lean-paid): R2 S3 API secret access key
AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>

# LOCAL (Docker self-hosted): us-east-1   |   CLOUD (lean-paid): auto
AWS_S3_REGION_NAME=auto

# LOCAL (Docker self-hosted): post   |   CLOUD (lean-paid): put
STORAGE_PRESIGN_METHOD=put

# --- Email: Brevo SMTP, optional ---
# If skipping email, leave this whole EMAIL_* section unset so production falls back to non-deliverable mail
# and the frontend hides "Forgot password?". Keeping EMAIL_BACKEND+EMAIL_HOST without valid SMTP credentials
# makes the app believe email is enabled.
# LOCAL (Docker self-hosted): omit to use Django's console backend default   |   CLOUD (lean-paid): django.core.mail.backends.smtp.EmailBackend
# REQUIRED for real email. Without this, mail only logs and email_enabled() reports off.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# LOCAL (Docker self-hosted): blank   |   CLOUD (lean-paid): smtp-relay.brevo.com
EMAIL_HOST=smtp-relay.brevo.com

# LOCAL (Docker self-hosted): 587   |   CLOUD (lean-paid): 587
EMAIL_PORT=587

# LOCAL (Docker self-hosted): blank   |   CLOUD (lean-paid): Brevo SMTP login
EMAIL_HOST_USER=<brevo-smtp-login>

# LOCAL (Docker self-hosted): blank   |   CLOUD (lean-paid): Brevo SMTP key
EMAIL_HOST_PASSWORD=<brevo-smtp-key>

# LOCAL (Docker self-hosted): True   |   CLOUD (lean-paid): True
EMAIL_USE_TLS=True

# LOCAL (Docker self-hosted): Makerspace <noreply@example.com>   |   CLOUD (lean-paid): Brevo-verified sender address
DEFAULT_FROM_EMAIL=Makerspace <noreply@example.org>

# --- Cron ---
# LOCAL (Docker self-hosted): blank, endpoint 404s   |   CLOUD (lean-paid): long random secret for X-Cron-Secret
CRON_SECRET=<long-random-secret>

# --- Frontend and public URLs ---
# LOCAL (Docker self-hosted): http://localhost:5000   |   CLOUD (lean-paid): https://<frontend-origin>
PUBLIC_APP_BASE_URL=https://<frontend-origin>

# --- Telegram, optional ---
# LOCAL (Docker self-hosted): blank   |   CLOUD (lean-paid): optional global fallback Telegram bot token
TELEGRAM_BOT_TOKEN=

# LOCAL (Docker self-hosted): blank, callbacks fail closed   |   CLOUD (lean-paid): random webhook secret registered with Telegram
TELEGRAM_WEBHOOK_SECRET=
