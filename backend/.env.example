SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ADMIN_SITE_NAME=Makerspace Inventory
DATABASE_URL=postgres://tinker:tinker@localhost:5432/tinkerspace
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173
HMAC_CLIENT_ID=
HMAC_SECRET=
HMAC_MAX_CLOCK_SKEW_SECONDS=300
HMAC_PROTECTED_PATH_PREFIXES=/api/public/,/api/v1/public/
# Fernet key for ApiClient secret encryption. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_CLIENT_ENC_KEY=

# Production (separate HTTPS origins): leave defaults (SameSite=None, Secure=True).
# Local dev: serve the frontend via a same-origin Vite proxy to :8000 and set:
# AUTH_COOKIE_SAMESITE=Lax
# AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=None
AUTH_COOKIE_SECURE=True

# MinIO evidence storage for host-dev. For a dockerized backend, use the internal
# endpoint (http://minio:9000) for AWS_S3_ENDPOINT_URL and the public endpoint
# (http://localhost:9000) for AWS_S3_PUBLIC_ENDPOINT_URL; out of scope this phase.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=evidence
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1
EVIDENCE_URL_TTL_SECONDS=300
EVIDENCE_MAX_BYTES=10485760

# Check-in verification defaults to a local permissive stub. Set CHECKIN_MODE=http
# only when CHECKIN_API_URL points at the real check-in service.
CHECKIN_MODE=stub
CHECKIN_API_URL=
CHECKIN_TIMEOUT=5.0

# Public request workflow throttle scopes.
THROTTLE_CHECKIN_VERIFY=30/min
THROTTLE_REQUEST_SUBMIT=10/min
THROTTLE_REQUEST_STATUS=60/min

# Email defaults use the console backend for local development.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=TinkerSpace <noreply@tinkerspace.local>
